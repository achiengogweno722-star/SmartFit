generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TRAINER
  MEMBER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum FitnessLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum FitnessGoal {
  WEIGHT_LOSS
  MUSCLE_GAIN
  STRENGTH
  ENDURANCE
  GENERAL_FITNESS
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
}

model User {
  id       Int    @id @default(autoincrement())
  fullName String
  email    String @unique
  password String
  role     Role   @default(MEMBER)

  memberProfile  MemberProfile?
  trainerProfile TrainerProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemberProfile {
  id     Int @id @default(autoincrement())
  userId Int @unique

  gender      Gender
  dateOfBirth DateTime
  height      Float
  weight      Float
  bmi         Float?

  fitnessLevel FitnessLevel
  fitnessGoal  FitnessGoal

  availableDaysPerWeek Int
  preferredWorkoutTime String?

  medicalConditions String?
  phoneNumber       String?
  address           String?
  emergencyContact  String?

  // Assigned Trainer
  trainerId Int?

  // Assigned Workout Plan
  workoutPlanId Int?

  user        User            @relation(fields: [userId], references: [id])
  trainer     TrainerProfile? @relation(fields: [trainerId], references: [id])
  workoutPlan WorkoutPlan?    @relation(fields: [workoutPlanId], references: [id])

  // Workout Recommendations
  recommendations Recommendation[]

  // Nutrition Recommendations
  nutritionRecommendations NutritionRecommendation[]

  // Progress Logs
  progressLogs ProgressLog[]

  // Workout Logs
  workoutLogs WorkoutLog[]

  // Attendance
  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([trainerId])
  @@index([workoutPlanId])
  @@index([fitnessGoal])
  @@index([fitnessLevel])
}

model TrainerProfile {
  id     Int @id @default(autoincrement())
  userId Int @unique

  specialization String
  experience     Int
  phoneNumber    String?

  user User @relation(fields: [userId], references: [id])

  members MemberProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([specialization])
}

model WorkoutPlan {
  id          Int    @id @default(autoincrement())
  name        String
  description String

  category   String
  targetGoal FitnessGoal

  difficulty FitnessLevel

  duration Int
  calories Int

  equipmentRequired Boolean @default(false)
  sessionsPerWeek   Int
  estimatedWeeks    Int
  isActive          Boolean @default(true)

  members MemberProfile[]

  recommendations Recommendation[]

  workoutLogs WorkoutLog[]

  exercises Exercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([difficulty])
  @@index([targetGoal])
  @@index([isActive])
}

model Exercise {
  id Int @id @default(autoincrement())

  workoutPlanId Int

  name        String
  description String

  sets Int

  reps Int?

  durationSeconds Int?

  restSeconds Int

  difficulty FitnessLevel

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  @@index([workoutPlanId])
}

model Recommendation {
  id Int @id @default(autoincrement())

  memberId      Int
  workoutPlanId Int

  recommendationScore Float
  reason              String

  member MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([memberId])
}

model MealPlan {
  id Int @id @default(autoincrement())

  name String

  goal FitnessGoal

  calories Int

  breakfast String

  lunch String

  dinner String

  snacks String?

  isActive Boolean @default(true)

  recommendations NutritionRecommendation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NutritionRecommendation {
  id Int @id @default(autoincrement())

  memberId   Int
  mealPlanId Int

  recommendationScore Float
  reason              String

  member MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  mealPlan MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([memberId])
}

model ProgressLog {
  id Int @id @default(autoincrement())

  memberId Int

  weight Float
  bmi    Float

  bodyFat Float?

  muscleMass Float?

  notes String?

  member MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([memberId])
}

model WorkoutLog {
  id Int @id @default(autoincrement())

  memberId      Int
  workoutPlanId Int

  completed Boolean @default(false)

  completionPercentage Int?

  durationCompleted Int?

  caloriesBurned Int?

  notes String?

  completedAt DateTime?

  createdAt DateTime @default(now())

  member MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([workoutPlanId])
}

model Attendance {
  id Int @id @default(autoincrement())

  memberId Int

  checkIn DateTime @default(now())

  checkOut DateTime?

  status AttendanceStatus @default(PRESENT)

  member MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([memberId])
}
